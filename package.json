{
  "name": "numnums",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm --filter @numnums/admin dev",
    "dev:customer": "pnpm --filter @numnums/customer dev",
    "build": "pnpm --filter @numnums/admin build",
    "build:customer": "pnpm --filter @numnums/customer build",
    "fetch:everyplate": "pnpm --filter @numnums/admin fetch:everyplate",
    "import:aldi": "pnpm --filter @numnums/admin import:aldi",
    "import:everyplate": "pnpm --filter @numnums/admin import:everyplate",
    "import:all": "pnpm --filter @numnums/admin import:all",
    "start": "pnpm --filter @numnums/admin start",
    "start:customer": "pnpm --filter @numnums/customer start",
    "typecheck": "pnpm --filter @numnums/admin typecheck",
    "typecheck:customer": "pnpm --filter @numnums/customer typecheck"
  }
}